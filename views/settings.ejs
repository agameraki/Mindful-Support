<!DOCTYPE html>
<html>
<head>
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/chat.css">
    <style>
        .settings-section {
            background: var(--white);
            border-radius: 25px;
            padding: 2rem;
            margin-bottom: 2rem;
            box-shadow: var(--shadow-sm);
        }
        
        .settings-section h2 {
            color: var(--accent-1);
            margin-bottom: 1.5rem;
            padding-bottom: 1rem;
            border-bottom: 3px solid var(--bg-primary);
        }
        
        .current-avatar {
            width: 100px;
            height: 100px;
            background: linear-gradient(135deg, var(--accent-1), var(--accent-2));
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 3rem;
            margin: 0 auto 1.5rem;
            border: 4px solid var(--white);
            box-shadow: var(--shadow-md);
        }
        
        .avatar-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(80px, 1fr));
            gap: 1rem;
            margin-top: 1rem;
        }
        
        .avatar-option {
            text-align: center;
            padding: 1rem;
            border: 3px solid var(--bg-primary);
            border-radius: 20px;
            cursor: pointer;
            transition: all 0.3s ease;
            background: var(--bg-primary);
        }
        
        .avatar-option:hover {
            border-color: var(--accent-1);
            transform: scale(1.05);
            box-shadow: var(--shadow-sm);
        }
        
        .avatar-option.selected {
            border-color: var(--accent-2);
            background: linear-gradient(135deg, #FFD8DF, #FFAAB8);
        }
        
        .avatar-emoji {
            font-size: 2.5rem;
            display: block;
            margin-bottom: 0.5rem;
        }
        
        .avatar-name {
            font-size: 0.8rem;
            color: var(--text-dark);
        }
        
        .theme-option {
            display: flex;
            align-items: center;
            padding: 1rem;
            border: 3px solid var(--bg-primary);
            border-radius: 20px;
            margin-bottom: 1rem;
            cursor: pointer;
            transition: all 0.3s ease;
        }
        
        .theme-option:hover {
            border-color: var(--accent-1);
            transform: translateX(5px);
        }
        
        .theme-option input[type="radio"] {
            width: 20px;
            height: 20px;
            margin-right: 1rem;
        }
    </style>
</head>
<body class="<%= (settings.theme || 'light') %>-theme">
    <div class="dashboard-layout">
        <!-- Sidebar Navigation -->
        <aside class="sidebar">
            <div class="sidebar-header">
                <h2>🫧 Mindful Support</h2>
            </div>
            
            <ul class="sidebar-nav">
                <li><a href="/dashboard">🏠 Dashboard</a></li>
                <li><a href="/mood/checkin">😊 Mood Check-in</a></li>
                <li><a href="/mood/history">📊 Mood History</a></li>
                <li><a href="/journal">📝 My Journal</a></li>
                <li><a href="/journal/new">✍️ New Journal Entry</a></li>
                <li><a href="/resources">🆘 Resources</a></li>
                <li><a href="/settings" class="active">⚙️ Settings</a></li>
                <li><a href="/logout">🚪 Logout</a></li>
            </ul>
        </aside>
        
        <!-- Main Content -->
        <main class="main-content">
            <div class="card">
                <h1>⚙️ Settings</h1>
                <p style="color: #666; margin-top: 0.5rem;">Customize your Mindful Support experience</p>
            </div>
            
            <% if (error) { %>
                <div class="card" style="background: #ffebee; border-left: 4px solid #f44336;">
                    <p style="color: #c62828; margin: 0;"><%= error %></p>
                </div>
            <% } %>
            
            <% if (success) { %>
                <div class="card" style="background: #e8f5e9; border-left: 4px solid #4caf50;">
                    <p style="color: #2e7d32; margin: 0;"><%= success %></p>
                </div>
            <% } %>
            
            <!-- Profile Settings -->
            <div class="settings-section">
                <h2>👤 Profile Information</h2>
                <form method="POST" action="/settings/profile">
                    <div class="form-group">
                        <label>Username</label>
                        <input type="text" name="username" value="<%= user.username %>" required>
                    </div>
                    
                    <div class="form-group">
                        <label>Email</label>
                        <input type="email" name="email" value="<%= user.email %>" required>
                    </div>
                    
                    <button type="submit" class="btn btn-primary">Update Profile</button>
                </form>
            </div>
            
            <!-- Avatar Selection -->
            <div class="settings-section">
                <h2>🎨 Choose Your Avatar</h2>
                <p style="color: #666; margin-bottom: 1rem;">Your Current Avatar:</p>
                <div class="current-avatar">
                    <% 
                    const currentAvatar = user.avatar || 'cat';
                    if (currentAvatar === 'cat') { %>🐱
                    <% } else if (currentAvatar === 'dog') { %>🐶
                    <% } else if (currentAvatar === 'bear') { %>🐻
                    <% } else if (currentAvatar === 'fox') { %>🦊
                    <% } else if (currentAvatar === 'rabbit') { %>🐰
                    <% } else if (currentAvatar === 'panda') { %>🐼
                    <% } else if (currentAvatar === 'koala') { %>🐨
                    <% } else if (currentAvatar === 'owl') { %>🦉
                    <% } else if (currentAvatar === 'penguin') { %>🐧
                    <% } else if (currentAvatar === 'lion') { %>🦁
                    <% } else if (currentAvatar === 'tiger') { %>🐯
                    <% } else if (currentAvatar === 'elephant') { %>🐘
                    <% } else if (currentAvatar === 'dolphin') { %>🐬
                    <% } else if (currentAvatar === 'butterfly') { %>🦋
                    <% } else if (currentAvatar === 'bird') { %>🐦
                    <% } else if (currentAvatar === 'fish') { %>🐠
                    <% } else if (currentAvatar === 'turtle') { %>🐢
                    <% } else if (currentAvatar === 'frog') { %>🐸
                    <% } else if (currentAvatar === 'bee') { %>🐝
                    <% } else if (currentAvatar === 'ladybug') { %>🐞
                    <% } %>
                </div>
                
                <form method="POST" action="/settings/avatar">
                    <div class="avatar-grid">
                        <% avatars.forEach(function(avatar) { %>
                            <label class="avatar-option <%= (user.avatar || 'cat') === avatar ? 'selected' : '' %>">
                                <input type="radio" name="avatar" value="<%= avatar %>" style="display: none;" <%= (user.avatar || 'cat') === avatar ? 'checked' : '' %>>
                                <span class="avatar-emoji">
                                    <% if (avatar === 'cat') { %>🐱
                                    <% } else if (avatar === 'dog') { %>🐶
                                    <% } else if (avatar === 'bear') { %>🐻
                                    <% } else if (avatar === 'fox') { %>🦊
                                    <% } else if (avatar === 'rabbit') { %>🐰
                                    <% } else if (avatar === 'panda') { %>🐼
                                    <% } else if (avatar === 'koala') { %>🐨
                                    <% } else if (avatar === 'owl') { %>🦉
                                    <% } else if (avatar === 'penguin') { %>🐧
                                    <% } else if (avatar === 'lion') { %>🦁
                                    <% } else if (avatar === 'tiger') { %>🐯
                                    <% } else if (avatar === 'elephant') { %>🐘
                                    <% } else if (avatar === 'dolphin') { %>🐬
                                    <% } else if (avatar === 'butterfly') { %>🦋
                                    <% } else if (avatar === 'bird') { %>🐦
                                    <% } else if (avatar === 'fish') { %>🐠
                                    <% } else if (avatar === 'turtle') { %>🐢
                                    <% } else if (avatar === 'frog') { %>🐸
                                    <% } else if (avatar === 'bee') { %>🐝
                                    <% } else if (avatar === 'ladybug') { %>🐞
                                    <% } %>
                                </span>
                                <span class="avatar-name"><%= avatar %></span>
                            </label>
                        <% }); %>
                    </div>
                    <button type="submit" class="btn btn-primary" style="margin-top: 1.5rem;">Save Avatar</button>
                </form>
            </div>
            
            <!-- Theme Toggle -->
            <div class="settings-section">
                <h2>🎨 Theme</h2>
                <form method="POST" action="/settings/theme">
                    <label class="theme-option">
                        <input type="radio" name="theme" value="light" <%= (settings.theme === 'light' || !settings.theme) ? 'checked' : '' %>>
                        <div>
                            <strong>☀️ Light Mode</strong>
                            <p style="margin: 0; color: #666; font-size: 0.9rem;">Bright and cheerful pastel colors</p>
                        </div>
                    </label>
                    
                    <label class="theme-option">
                        <input type="radio" name="theme" value="dark" <%= settings.theme === 'dark' ? 'checked' : '' %>>
                        <div>
                            <strong>🌙 Dark Mode</strong>
                            <p style="margin: 0; color: #666; font-size: 0.9rem;">Elegant dark colors for nighttime</p>
                        </div>
                    </label>
                    
                    <button type="submit" class="btn btn-primary" style="margin-top: 1rem;">Save Theme</button>
                </form>
            </div>
            
            <!-- Change Password -->
            <div class="settings-section">
                <h2>🔒 Change Password</h2>
                <form method="POST" action="/settings/password">
                    <div class="form-group">
                        <label>Current Password</label>
                        <input type="password" name="current_password" required>
                    </div>
                    
                    <div class="form-group">
                        <label>New Password</label>
                        <input type="password" name="new_password" required minlength="6">
                    </div>
                    
                    <div class="form-group">
                        <label>Confirm New Password</label>
                        <input type="password" name="confirm_password" required minlength="6">
                    </div>
                    
                    <button type="submit" class="btn btn-primary">Change Password</button>
                </form>
            </div>
        </main>
    </div>
    
    <!-- Chat Button -->
    <button id="chat-button" class="chat-button">🫧</button>
    
    <!-- Chat Window -->
    <div id="chat-window" class="chat-window">
        <div class="chat-header">
            <h3>🫧 Dodo - Your Wellness Companion</h3>
            <button id="chat-close" class="chat-close">&times;</button>
        </div>
        <div id="chat-messages" class="chat-messages"></div>
        <div class="chat-input">
            <input type="text" id="chat-input" placeholder="Type a message...">
            <button id="chat-send">Send</button>
        </div>
    </div>
    
    <script src="/js/chat.js"></script>
    <script>
        // Make avatar options clickable
        document.querySelectorAll('.avatar-option').forEach(option => {
            option.addEventListener('click', function() {
                document.querySelectorAll('.avatar-option').forEach(o => o.classList.remove('selected'));
                this.classList.add('selected');
                this.querySelector('input').checked = true;
            });
        });
    </script>
</body>
</html>