<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mindful Support - Your Mental Wellness Companion</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="landing-page">
        <div class="cafe-scene">
            <!-- Trees -->
            <div class="tree tree-1">
                <div class="tree-leaves"></div>
                <div class="tree-trunk"></div>
            </div>
            
            <div class="tree tree-2">
                <div class="tree-leaves"></div>
                <div class="tree-trunk"></div>
            </div>
            
            <!-- Plants -->
            <div class="plant plant-1">
                <div class="plant-leaves"></div>
                <div class="pot"></div>
            </div>
            
            <div class="plant plant-2">
                <div class="plant-leaves"></div>
                <div class="pot"></div>
            </div>
            
            <!-- Cafe Table with Coffee -->
            <div class="cafe-table">
                <div class="coffee-cup">
                    <div class="steam"></div>
                </div>
                <div class="table-top"></div>
                <div class="table-leg"></div>
            </div>
            
            <!-- Hero Content -->
            <div class="hero-content">
                <h1>Mindful Support</h1>
                <p class="hero-quote">
                    "Take a deep breath. You are not alone on this journey. 
                    Every step forward, no matter how small, is progress."
                </p>
                
                <div class="hero-buttons">
                    <a href="/signup" class="btn btn-primary">Get Started</a>
                    <a href="/login" class="btn btn-secondary">Login</a>
                </div>
            </div>
        </div>
    </div>
</body>
</html>