<!DOCTYPE html>
<html>
<head>
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/chat.css">
</head>
<body class="<%= (theme || 'light') %>-theme">
    <div class="dashboard-layout">
        <!-- Sidebar Navigation -->
        <aside class="sidebar">
            <div class="sidebar-header">
                <h2>🫧 Mindful Support</h2>
            </div>
            
            <ul class="sidebar-nav">
                <li><a href="/dashboard">🏠 Dashboard</a></li>
                <li><a href="/mood/checkin" class="active">😊 Mood Check-in</a></li>
                <li><a href="/mood/history">📊 Mood History</a></li>
                <li><a href="/journal">📝 My Journal</a></li>
                <li><a href="/journal/new">✍️ New Journal Entry</a></li>
                <li><a href="/resources">🆘 Resources</a></li>
                <li><a href="/settings">⚙️ Settings</a></li>
                <li><a href="/logout">🚪 Logout</a></li>
            </ul>
        </aside>
        
        <!-- Main Content -->
        <main class="main-content">
            <div class="card">
                <h1>😊 How are you feeling today?</h1>
                <p style="color: #666; margin-top: 0.5rem;">Take a moment to check in with yourself</p>
            </div>
            
            <% if (error) { %>
                <div class="card" style="background: #ffebee; border-left: 4px solid #f44336;">
                    <p style="color: #c62828; margin: 0;"><%= error %></p>
                </div>
            <% } %>
            
            <% if (success) { %>
                <div class="card" style="background: #e8f5e9; border-left: 4px solid #4caf50;">
                    <p style="color: #2e7d32; margin: 0;"><%= success %></p>
                </div>
            <% } %>
            
            <div class="card">
                <form method="POST" action="/mood/checkin">
                    <div class="form-group">
                        <label>Mood Score (1-10)</label>
                        <p style="color: #999; font-size: 0.9rem; margin-bottom: 1rem;">1 = Very Low | 10 = Excellent</p>
                        <input type="number" name="mood_score" min="1" max="10" placeholder="Rate your mood" required>
                    </div>
                    
                    <div class="form-group">
                        <label>Emotions (Optional)</label>
                        <p style="color: #999; font-size: 0.9rem; margin-bottom: 1rem;">e.g., happy, anxious, calm, stressed</p>
                        <input type="text" name="emotions" placeholder="happy, calm, grateful">
                    </div>
                    
                    <div class="form-group">
                        <label>Triggers (Optional)</label>
                        <p style="color: #999; font-size: 0.9rem; margin-bottom: 1rem;">What influenced your mood?</p>
                        <input type="text" name="triggers" placeholder="work, family, exercise, sleep">
                    </div>
                    
                    <div class="form-group">
                        <label>Notes (Optional)</label>
                        <p style="color: #999; font-size: 0.9rem; margin-bottom: 1rem;">Any additional thoughts?</p>
                        <textarea name="notes" rows="4" placeholder="Share anything on your mind..."></textarea>
                    </div>
                    
                    <button type="submit" class="btn btn-primary" style="width: 100%;">
                        Submit Check-in
                    </button>
                </form>
            </div>
        </main>
    </div>
    
    <!-- Chat Button -->
    <button id="chat-button" class="chat-button">🫧</button>
    
    <!-- Chat Window -->
    <div id="chat-window" class="chat-window">
        <div class="chat-header">
            <h3>🫧 Dodo - Your Wellness Companion</h3>
            <button id="chat-close" class="chat-close">&times;</button>
        </div>
        <div id="chat-messages" class="chat-messages"></div>
        <div class="chat-input">
            <input type="text" id="chat-input" placeholder="Type a message...">
            <button id="chat-send">Send</button>
        </div>
    </div>
    
    <script src="/js/chat.js"></script>
</body>
</html>