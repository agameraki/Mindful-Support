<!DOCTYPE html>
<html>
<head>
    <title><%= title %></title>
</head>
<body>
    <h1>Resources & Support</h1>
    
    <% 
    const grouped = {};
    resources.forEach(r => {
        if (!grouped[r.category]) grouped[r.category] = [];
        grouped[r.category].push(r);
    });
    %>
    
    <% if (grouped.crisis) { %>
        <div style="background: #ffebee; padding: 15px; margin: 10px 0; border-left: 4px solid red;">
            <h2>🆘 Crisis Resources - Available 24/7</h2>
            <% grouped.crisis.forEach(function(resource) { %>
                <div style="margin: 10px 0;">
                    <h3><%= resource.title %></h3>
                    <p><%= resource.description %></p>
                    <% if (resource.url) { %>
                        <a href="<%= resource.url %>" target="_blank" style="color: red; font-weight: bold;">Get Help Now</a>
                    <% } %>
                </div>
            <% }); %>
        </div>
    <% } %>
    
    <% if (grouped.breathing) { %>
        <div style="background: #e3f2fd; padding: 15px; margin: 10px 0;">
            <h2>🌬️ Breathing Exercises</h2>
            <% grouped.breathing.forEach(function(resource) { %>
                <div style="margin: 10px 0;">
                    <h3><%= resource.title %></h3>
                    <p><%= resource.description %></p>
                </div>
            <% }); %>
        </div>
    <% } %>
    
    <% if (grouped.meditation) { %>
        <div style="background: #f3e5f5; padding: 15px; margin: 10px 0;">
            <h2>🧘 Meditation</h2>
            <% grouped.meditation.forEach(function(resource) { %>
                <div style="margin: 10px 0;">
                    <h3><%= resource.title %></h3>
                    <p><%= resource.description %></p>
                </div>
            <% }); %>
        </div>
    <% } %>
    
    <% if (grouped.article) { %>
        <div style="background: #fff3e0; padding: 15px; margin: 10px 0;">
            <h2>📚 Articles</h2>
            <% grouped.article.forEach(function(resource) { %>
                <div style="margin: 10px 0;">
                    <h3><%= resource.title %></h3>
                    <p><%= resource.description %></p>
                </div>
            <% }); %>
        </div>
    <% } %>
    
    <br>
    <a href="/dashboard">Back to Dashboard</a>
</body>
</html>